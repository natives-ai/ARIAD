{
  "name": "scenaairo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "shared",
    "recommendation",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace @scenaairo/frontend -- --host 127.0.0.1 --port 5173",
    "dev:backend": "npm run dev --workspace @scenaairo/backend",
    "host:local": "powershell -ExecutionPolicy Bypass -File scripts/launch-local.ps1",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "integration": "npm run integration --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
