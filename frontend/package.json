  },
  "dependencies": {
    "@scenaairo/recommendation": "workspace:*",
    "@scenaairo/shared": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  }
}
