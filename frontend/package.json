{
  "name": "@scenaairo/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn run -T vite",
    "build": "yarn run -T tsc -p tsconfig.app.json --noEmit && yarn run -T vite build",
    "typecheck": "yarn run -T tsc -p tsconfig.app.json --noEmit && yarn run -T tsc -p tsconfig.node.json --noEmit",
    "lint": "yarn run -T eslint src --max-warnings=0",
    "test": "yarn run -T vitest run"
  },
  "dependencies": {
    "@scenaairo/recommendation": "file:../recommendation",
    "@scenaairo/shared": "file:../shared",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1"
  }
}
