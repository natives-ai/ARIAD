{
  "name": "@scenaairo/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run --exclude src/**/*.integration.test.ts",
    "integration": "vitest run --pool threads src/persistence/routes.integration.test.ts src/recommendation/routes.integration.test.ts"
  },
  "dependencies": {
    "@scenaairo/recommendation": "workspace:*",
    "@scenaairo/shared": "workspace:*",
    "fastify": "^5.8.5"
  }
}
