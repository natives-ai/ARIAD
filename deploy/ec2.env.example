# 이 파일은 EC2 Docker Compose 실행에 필요한 환경 변수 예시입니다.

# Public origin users open in the browser.
# Examples:
# FRONTEND_ORIGIN=http://12.34.56.78
# FRONTEND_ORIGIN=https://ariad.example.com
FRONTEND_ORIGIN=http://YOUR_EC2_PUBLIC_IP
ARIAD_HTTP_PORT=80

# Use true only when HTTPS terminates before the frontend container.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_SESSION_COOKIE_NAME=scenaairo_session
AUTH_SESSION_TTL_SECONDS=2592000
BACKEND_LOG_LEVEL=info
BACKEND_LOG_REQUESTS=true

# Google OAuth client id. This value is also injected into the frontend build.
GOOGLE_CLIENT_ID=

# MySQL credentials. Replace before running on EC2.
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=ariad
MYSQL_USER=ariad
MYSQL_PASSWORD=change-this-app-password
MYSQL_READINESS_TIMEOUT_MS=3000

# Recommendation provider.
# Use heuristic to run without an external LLM key.
RECOMMENDATION_PROVIDER=heuristic
RECOMMENDATION_MODEL=gpt-4.1-mini
RECOMMENDATION_FALLBACK_TO_HEURISTIC_ON_ERROR=false
RECOMMENDATION_TIMEOUT_MS=4000
RECOMMENDATION_CACHE_TTL_MS=30000
RECOMMENDATION_MAX_SUGGESTIONS=18
GEMINI_API_KEY=
OPENAI_API_KEY=
RECOMMENDATION_API_KEY=

VITE_STORAGE_PREFIX=ARIAD
